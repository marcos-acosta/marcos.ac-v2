---
import { tagNameToColor } from "./../util";

interface Props {
  tagName: string;
}

const { tagName } = Astro.props;

const color = tagNameToColor(tagName);
---

<a class="tagLink" href=`/tags/${tagName}`>
  <div class="tagContainer" style={`background-color: var(--tag-${color})`}>
    #{tagName}
  </div>
</a>

<style>
  .tagContainer {
    display: inline-block;
    padding: 0 3px;
    border-radius: 5px;
  }
</style>
