---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import PageLayout from "../layouts/PageLayout.astro";
import PageContent from "../layouts/PageContent.astro";
import PostPreviewList from "../components/PostPreviewList.astro";

const allPosts = await getCollection("blog");

const posts = allPosts
  .filter((p) => p.data.pinned)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const numPostsToShow = 5;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <PageLayout>
      <Header />
      <PageContent>
        <section>
          <h3 class="welcome">Welcome!</h3>
          <p>
            I'm Marcos&mdash; I'm a software engineer by trade (and aspiring
            polymath all the time) based in Brooklyn. I graduated from Harvey
            Mudd College with a CS degree in 2023 and currently work on the Play
            Store at <a href="https://bing.com" target="_blank" rel="noreferrer"
              >Google</a
            >, where I help build <a
              href="https://techcrunch.com/2024/07/24/google-play-launches-curated-spaces-feature-manga-anime/"
              target="_blank"
              rel="noreferrer"
            >
              features</a
            > related to app recommendations. Some of my regular activities in the
            city include jamming, hanging out in <a
              href="https://www.instagram.com/creativecodingnyc/"
              target="_blank"
              rel="noreferrer"
            >
              collaborative</a
            >{" "}<a
              href="https://sideprojectsaturday.com/"
              target="_blank"
              rel="noreferrer">spaces</a
            >,
            <a
              href="https://www.tiktok.com/@worlds.worst.detective"
              target="_blank"
              rel="noreferrer"
            >
              reviewing subway stations</a
            >, and generally trying to keep up with all the <a
              href="https://wikigamejam.org/"
              target="_blank"
              rel="noreferrer">nerdy</a
            >
            <a
              href="https://www.wonderville.nyc/events/wordhack-july-2024"
              target="_blank"
              rel="noreferrer">events</a
            > NYC has to offer.
          </p>
          <p>
            If you'd like to reach me, you can find my contact <a
              href="/resume.pdf"
              target="_blank">here</a
            >. Otherwise, feel free to read through anything here that catches
            your attention.
          </p>
          <p>
            Note that I'm in the process of "fast forwarding" my blog to catch
            up with all of my projects, so some blog posts will be stubs until I
            have a chance to expand on them.
          </p>
        </section>
        <section>
          <h3>Pinned posts</h3>
          <p>
            <PostPreviewList posts={posts} />
          </p>
          <a href="/blog">See all {allPosts.length} posts⤼</a>
        </section>
      </PageContent>
    </PageLayout>
  </body>
</html>
