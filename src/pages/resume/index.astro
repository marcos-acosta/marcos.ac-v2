---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import PageContent from "../../layouts/PageContent.astro";
import PageLayout from "../../layouts/PageLayout.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <PageLayout>
      <Header />
      <PageContent>
        <h3>Resume</h3>
        <div class="resumeContainer">
          <iframe src="/v1.0.0.pdf" frameborder="0" class="resumeFrame"
          ></iframe>
          <!-- Mobile: provide clear download link -->
          <a href="/v1.0.0.pdf" class="mobile-download" download>
            Download Resume (PDF)
          </a>
        </div>
      </PageContent>
    </PageLayout>
  </body>
</html>

<style>
  .resumeContainer {
    width: 100%;
    padding-top: 10px;
  }

  .resumeFrame {
    width: 100%;
    height: 800px;
  }
</style>
